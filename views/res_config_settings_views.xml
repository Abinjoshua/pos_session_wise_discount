<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Define a view to extend POS configuration settings with delivery options -->
    <record id="view_pos_discount_limit_form" model="ir.ui.view">
        <field name="name">pos.discount.limit.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='is_restaurant']"
                   position="after">
                <setting id="discount_limit"
                         documentation="https://www.cybrosys.com/"
                         title="User can set the discount limit session wise"
                         help="Set the session wise discount limit"
                >
                    <field name="is_session_discount_limit"/>
                    <div class="content-group"
                         invisible="not is_session_discount_limit">
                        <div class="mt16">
                            <field name="session_discount_limit"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
