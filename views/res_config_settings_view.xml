<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_discount" model="ir.ui.view">
        <field name="name">res.config.settings.discount</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='point_of_sale']" position="inside">
                <block title="Discount Settings">
                    <setting string="Discount Limit">
                        <field name="discount_limit"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
